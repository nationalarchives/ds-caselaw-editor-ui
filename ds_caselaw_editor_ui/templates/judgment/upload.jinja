{% extends "layouts/judgment.jinja" %}
{% from "components/heading.jinja" import heading %}
{% from "components/note_form.jinja" import note_form %}
{% from "components/notification.jinja" import notification %}
{% block content %}
  <div class="container">
    {{ heading(content="Upload a document against:") }}
    {{ heading(tag="h2", weight="normal", content=judgment.body.name) }}
    {% if document.is_published %}
      {% call notification(variant="warning") %}
        You cannot upload documents while this document is published. Unpublish it first to upload additional documents.
      {% endcall %}
    {% else %}
      <p>It will be uploaded to {{ upload_path }}</p>
      <form action="{{ url('upload') }}"
            method="post"
            enctype="multipart/form-data">
        {{ csrf_input }}
        <input type="hidden" name="judgment_uri" value="{{ judgment.uri }}" />
        {% if waffle.flag("notes_on_state_change") %}{{ note_form() }}{% endif %}
        {{ upload_input }}
        <p>{{ button(content="Upload docment") }}</p>
        <p>
          <a href="{{ url('full-text-html', document.uri) }}">Go back to review</a>
        </p>
      </form>
    {% endif %}
  </div>
{% endblock content %}
