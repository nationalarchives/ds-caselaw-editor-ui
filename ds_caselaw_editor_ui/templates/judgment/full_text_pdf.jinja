{% extends "layouts/judgment.jinja" %}
{% from "components/document_metadata.jinja" import document_metadata with context %}
{% from "components/tabs.jinja" import tabs, tab %}
{% block content %}
  {{ document_metadata(variant=("edit" if document_type == "judgment" else "view") ) }}
  {% if document_html %}
    {% call tabs() %}
      {{ tab(id="html", name="html", index=0, url=url("full-text-html", document.uri) , label="HTML view") }}
      {{ tab(id="pdf", name="pdf", index=1, selected=True, url=url("full-text-pdf", document.uri) , label="PDF view") }}
    {% endcall %}
  {% endif %}
  <object data="{{ document.pdf_url }}"
          type="application/pdf"
          width="100%"
          height="800px">
    Your browser cannot display this embedded PDF. <a href="{{ document.pdf_url }}">Download it here</a>.
  </object>
{% endblock content %}
