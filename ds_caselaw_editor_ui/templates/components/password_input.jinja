{% from "govuk_frontend_jinja/components/password-input/macro.html" import govukPasswordInput %}
{% macro password_input(field) %}
  {% set errors = {"text": field.errors | join(", ")} if field.errors else None %}
  {% set value = field.value if field is mapping else (field.value() if field.value is callable else field.value) %}
  {% set label_classes = {"default": "govuk-label--s", "extra-small": "govuk-label--xs"} %}
  {% set label_class = label_classes.get(field.label_size, label_classes["default"]) %}
  {% set width_classes = {
    "full": "govuk-!-width-full",
    "three-quarters": "govuk-!-width-three-quarters",
    "two-thirds": "govuk-!-width-two-thirds",
    "one-half": "govuk-!-width-one-half",
    "one-third": "govuk-!-width-one-third",
    "one-quarter": "govuk-!-width-one-quarter"
  } %}
  {% set width_class = width_classes.get(field.width, "") %}
  {% set margin_classes = {"default": "", "small": "govuk-!-margin-bottom-4"} %}
  {% set margin_class = margin_classes.get(field.margin, "") %}
  {{ govukPasswordInput({
    "label":       { "text": field.label, "classes": label_class },
    "id":          field.id_for_label,
    "name":        field.html_name,
    "value":       value,
    "formGroup":   { "classes": width_class ~ " " ~ margin_class, "beforeInput": "" },
    "errorMessage": errors
    }) }}
{% endmacro %}
