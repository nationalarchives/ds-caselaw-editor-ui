{% extends "layouts/base.jinja" %}
{% from "components/button.jinja" import button %}
{% from "components/form_field.jinja" import form_field %}
{% from "components/heading.jinja" import heading %}
{% block breadcrumbs %}
  <li>Password reset</li>
{% endblock breadcrumbs %}
{% block content %}
  <div class="login-background">
    <div class="login-container">
      <form method="post" action="{{ url('account_reset_password') }}">
        {% call heading() %}
          Password reset
        {% endcall %}
        {{ csrf_input }}
        {{ form.non_field_errors() }}
        {{ form_field(form.email) }}
        {% if redirect_field %}{{ redirect_field }}{% endif %}
        {{ button(content="Reset password") }}
      </form>
    </div>
  </div>
{% endblock content %}
